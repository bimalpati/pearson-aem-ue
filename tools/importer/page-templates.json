        },
        {
          "id": "section-5",
          "name": "Important Purchasing Details",
          "selector": "main section.bgcolor--ui-01.has-padding-top--none.has-padding-bottom--45",
          "style": null,
          "blocks": [],
          "defaultContent": [
            "main section.bgcolor--ui-01.has-padding-top--none.has-padding-bottom--45 .content-tile-text"
          ]
        }
      ]
    },
    {
